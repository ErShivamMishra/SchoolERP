{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SchoolERPDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "SchoolERP",
    "Audience": "SchoolERP.Client",
    "SecretKey": "ThisIsADevelopmentOnlySecretKey1234567890!",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Auth": {
    "FailedLoginThreshold": 5,
    "LockoutDurationMinutes": 15,
    "SeedSuperAdmin": {
      "FullName": "Platform Super Admin",
      "Email": "superadmin@schoolerp.local",
      "Password": "SuperAdmin@123"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
